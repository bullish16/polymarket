# ==============================
# Polymarket Bot Configuration
# ==============================
# Copy this to .env and fill in your values
# NEVER commit .env to git!

# Your Polygon wallet private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Signature type: 0=EOA, 1=POLY_PROXY (MagicLink/email), 2=GNOSIS_SAFE
# Most consumer Polymarket accounts = 1
SIGNATURE_TYPE=1

# Polymarket API key & secret (get from setup_creds.py or Polymarket settings)
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# Trading config
BET_SIZE=1.00
MIN_DELTA_PCT=0.05
TARGET_PROFIT=0.30

# Optional: proxy (if VPS location is restricted)
# HTTP_PROXY=socks5://user:pass@host:port
# HTTPS_PROXY=socks5://user:pass@host:port
